{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(uv run:*)",
      "Bash(git log:*)",
      "Bash(terminal-notifier:*)"
    ],
    "deny": []
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/andy16/.local/bin/dcg"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/andy16/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "alwaysThinkingEnabled": false
}
