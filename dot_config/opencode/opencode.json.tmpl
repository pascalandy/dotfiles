        "kimi-zen": {
          "disable": true,
          "id": "kimi-k2.5",
          "name": "Kimi K2.5 (Zen)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "glm-zen": {
          "id": "glm-5",
          "name": "GLM 5 (Zen)",
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 131072,
            "output": 16384
          }
        },
        "minimax-m2.7": {
          "id": "minimax-m2.7",
          "name": "MiniMax M2.7 (Zen)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        }
      }
    },
    "fireworks-ai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Fireworks AI",
      "options": {
        "baseURL": "https://api.fireworks.ai/inference/v1"
      },
      "models": {
        "accounts/fireworks/routers/kimi-k2p5-turbo": {
          "id": "accounts/fireworks/routers/kimi-k2p5-turbo",
          "name": "Kimi K2.5 Turbo (Fireworks)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "limit": {
            "context": 262144,
            "output": 16384
          }
        }
      }
    }
