  "mcp": {
    "exa": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server", "tools=web_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check"],
      "environment": {
        "EXA_API_KEY": "{{ keyring "exa" "api_key" }}"
      },
      "timeout": 60000
    }
  },
  "provider": {
    "zai-coding-plan": {
      "name": "zai-coding-plan",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "timeout": 600000
      },
      "models": {
        "glm-5": {
          "name": "GLM 5",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 200000,
            "output": 128000
          }
        }
      }
    },
    "anthropic": {
      "name": "anthropic",
      "models": {
        "claude-sonnet-4-6": {
          "name": "Sonnet 4.6",
          "tool_call": true,
          "temperature": true
        }
      }
    },
    "openai": {
      "name": "openai",
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4",
          "limit": {
            "context": 400000,
            "output": 128000
          }
        }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{{ keyring "openrouter" "api_key" }}"
      },
      "models": {
        "deepseek/deepseek-v3.2": {
          "id": "deepseek/deepseek-v3.2",
          "name": "DeepSeek: DeepSeek V3.2",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 131000,
            "output": 64000
          },
          "cost": {
            "input": 0.28,
            "output": 0.42
          }
        },
        "mistralai/devstral-2512:free": {
          "id": "mistralai/devstral-2512:free",
          "name": "Mistral: Devstral 2 2512 (free)",
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 262144,
            "output": 65536
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        },
        "moonshotai/kimi-k2.5:nitro": {
          "id": "moonshotai/kimi-k2.5:nitro",
          "name": "Kimi K2.5 Nitro",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "variants": {
            "instant": {
              "reasoning": {
                "enabled": false
              }
            },
            "thinking": {
              "reasoning": {
                "effort": "high"
              }
            }
          },
          "limit": {
            "context": 262144,
            "output": 16384
          },
          "cost": {
            "input": 0.60,
            "output": 3.0
          }
        },
        "google/gemini-3-flash-preview": {
          "id": "google/gemini-3-flash-preview",
          "name": "Gemini 3 Flash Preview (OpenRouter)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "interleaved": {
            "field": "reasoning_details"
          },
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf", "audio", "video"],
            "output": ["text"]
          },
          "cost": {
            "input": 0.50,
            "output": 3.00
          }
        },
        "x-ai/grok-4.20-beta": {
          "id": "x-ai/grok-4.20-beta",
          "name": "Grok 4.20 Beta",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "limit": {
            "context": 2000000,
            "output": 30000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "cost": {
            "input": 2.0,
            "output": 6.0
          }
        },
        "stepfun/step-3.5-flash:free": {
          "id": "stepfun/step-3.5-flash:free",
          "name": "Step 3.5 Flash (Free)",
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        },
        "xiaomi/mimo-v2-pro": {
          "id": "xiaomi/mimo-v2-pro",
          "name": "Xiaomi: Mimo V2 Pro",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "limit": {
            "context": 131072,
            "output": 16384
          }
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "lmstudio",
      "options": {
        "baseURL": "http://127.0.0.1:1235/v1"
