      "temperature": 0.2,
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      },
      "options": {
        "thinking": {
          "type": "adaptive"
        },
        "effort": "low"
      }
    },
    // ==========================================================
    // Subagents (organized by provider/purpose)
    // ==========================================================
    "kimi": {
      "description": "Kimi 2.5 Turbo preset.",
      "disable": false,
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
