{
  "$schema": "https://opencode.ai/config.json",
  // ==================================================
  // Open Questions & Decisions look in my /docs: `how-my-opencode-is-configured.md`
  // ==================================================
  "default_agent": "1-kimi",
  "small_model": "gptmini",
  "agent": {
    // ==========================================================
    // Built-in agents (disabled)
    // ==========================================================
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    // ==========================================================
    // Primary agents (ordered for Tab cycling)
    // ==========================================================
    "1-kimi": {
      "description": "Kimi 2.5 Turbo preset.",
      "disable": false,
      "mode": "all",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "temperature": 0.2,
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      }
    },
    "2-gpt": {
      "description": "GPT-5.4 preset.",
      "disable": false,
      "mode": "all",
      "model": "openai/gpt-5.4",
      "temperature": 0.2,
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      },
      "options": {
        "reasoning": {
          "effort": "high",
          "summary": "none"
        },
        "text": {
          "verbosity": "low"
        }
      }
    },
    "3-glm": {
      "description": "GLM 5.1",
      "disable": false,
      "mode": "all",
      "model": "zai-coding-plan/glm-5.1",
      "temperature": 0.1,
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      },
      "options": {
        "thinking": {
          "type": "enabled"
        }
      }
    },
    "opus": {
      "description": "Primary Claude thinking preset.",
      "disable": true,
      "mode": "all",
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0.2,
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      },
      "options": {
        "thinking": {
          "type": "adaptive"
        },
        "effort": "low"
      }
