#!/usr/bin/env bash
#
# ==============================================================================
# update-cli - Update CLI tools in parallel
# ==============================================================================
# Updates brew packages, uv tools, bun packages, and custom binaries.
# Runs updates in parallel for speed, with clear success/failure reporting.
#
# Maintenance notes:
# - Group tools by package manager when they share the same command pattern.
# - Prefer arrays + loops for simple "same command, different package" updates.
# - Keep one-off commands explicit when they need unique arguments or behavior.
# - When adding a new tool, update both the help text and the matching array/command.
# - For Bun global CLIs, use: bun add -g <package>
# ==============================================================================

readonly SCRIPT_VERSION="1.3.0"
readonly SCRIPT_AUTHOR="Pascal Andy"
readonly SCRIPT_DESCRIPTION="Update CLI tools (brew, uv, bun, update-bin) in parallel."

readonly SCRIPT_PATH="${BASH_SOURCE[0]}"
readonly SCRIPT_NAME="${SCRIPT_PATH##*/}"

# ==============================================================================
# Runtime options
# ==============================================================================

VERBOSE=0
DRY_RUN=0
NO_COLOR="${NO_COLOR:-}"

# ==============================================================================
# Strict mode
# ==============================================================================

set -euo pipefail

# ==============================================================================
# Logging
# ==============================================================================

fct_ansi() {
	local code="${1}"
	if [[ -t 2 && -z "${NO_COLOR}" ]]; then
		printf '\033[%sm' "${code}"
	fi
}

log_info() {
	local reset=""
	local prefix=""
	if [[ -t 2 && -z "${NO_COLOR}" ]]; then
		prefix="$(fct_ansi '32')"
		reset="$(fct_ansi '0')"
	fi
	printf '%s%s%s\n' "${prefix}" "$*" "${reset}" >&2
}

log_warn() {
	local reset=""
	local prefix=""
	if [[ -t 2 && -z "${NO_COLOR}" ]]; then
		prefix="$(fct_ansi '33')"
		reset="$(fct_ansi '0')"
	fi
	printf '%s%s%s\n' "${prefix}" "$*" "${reset}" >&2
}

log_error() {
	local reset=""
	local prefix=""
	if [[ -t 2 && -z "${NO_COLOR}" ]]; then
		prefix="$(fct_ansi '31')"
		reset="$(fct_ansi '0')"
	fi
	printf '%s%s%s\n' "${prefix}" "$*" "${reset}" >&2
}

log_debug() {
	if [[ "${VERBOSE}" -eq 1 ]]; then
		local reset=""
		local prefix=""
		if [[ -t 2 && -z "${NO_COLOR}" ]]; then
			prefix="$(fct_ansi '36')"
			reset="$(fct_ansi '0')"
		fi
		printf '%s[DEBUG] %s%s\n' "${prefix}" "$*" "${reset}" >&2
	fi
}

# ==============================================================================
# Usage
# ==============================================================================

usage() {
	cat <<EOF
${SCRIPT_NAME} v${SCRIPT_VERSION}
${SCRIPT_DESCRIPTION}
Author: ${SCRIPT_AUTHOR}

Usage:
  ${SCRIPT_NAME} [options]

Options:
  -h, --help       Show this help and exit
  -V, --version    Show version and exit
  -v, --verbose    Enable debug logging
  -n, --dry-run    Show what would be updated without running
      --no-color   Disable colored output

Tools updated:
  Brew:       codex, uv
  update-bin: gemini, kilocode, gh, repomix
  UV tools:   specify-cli, playwright, all uv tools
  Bun:        btca, opencode-ai, pi-coding-agent, defuddle-cli, qmd, googleworkspace/cli, agent-browser
  Other:      amp, claude (install.sh), specify check

Examples:
  ${SCRIPT_NAME}              # Update all CLI tools
  ${SCRIPT_NAME} -v           # Update with verbose output
  ${SCRIPT_NAME} --dry-run    # Show what would be updated
EOF
}

# ==============================================================================
# Argument parsing
# ==============================================================================

fct_parse_arguments() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
		-h | --help)
			usage
			exit 0
			;;
		-V | --version)
			printf '%s\n' "${SCRIPT_NAME} v${SCRIPT_VERSION}"
			exit 0
			;;
		-v | --verbose)
			VERBOSE=1
			shift
			;;
		-n | --dry-run)
			DRY_RUN=1
			shift
			;;
		--no-color)
			NO_COLOR="1"
			shift
			;;
		-*)
			log_error "Unknown option: $1"
			usage
			exit 2
			;;
		*)
			log_error "Unexpected argument: $1"
			usage
			exit 2
			;;
		esac
	done
}

# ==============================================================================
# Update helpers
# ==============================================================================

fct_run_update() {
	local name="${1}"
	shift
	local cmd=("$@")

	if [[ "${DRY_RUN}" -eq 1 ]]; then
		log_info "[DRY-RUN] Would run: ${cmd[*]}"
		return 0
	fi

	log_debug "Running: ${cmd[*]}"
	if "${cmd[@]}" >/dev/null 2>&1; then
		echo "✓ ${name}"
	else
		echo "✗ ${name} failed"
	fi
}

fct_queue_update() {
	local pids_name="${1}"
	shift

	fct_run_update "$@" &
	local pid=$!
	eval "${pids_name}+=(\"${pid}\")"
}

fct_queue_brew_updates() {
	local pids_name="${1}"
	local brew_tools=(codex uv)
	local tool=""

	for tool in "${brew_tools[@]}"; do
		fct_queue_update "${pids_name}" "${tool} (brew)" brew upgrade "${tool}"
	done
}

fct_queue_update_bin_updates() {
	local pids_name="${1}"
	local update_bin_tools=(gemini kilocode gh repomix)
	local tool=""

	for tool in "${update_bin_tools[@]}"; do
		fct_queue_update "${pids_name}" "${tool} (update-bin)" update-bin "${tool}"
	done
}

fct_queue_bun_updates() {
	local pids_name="${1}"
	local bun_tools=(
		btca
		opencode-ai
		@mariozechner/pi-coding-agent
		defuddle-cli
		@tobilu/qmd
		@googleworkspace/cli
		agent-browser
	)
	local tool=""

	for tool in "${bun_tools[@]}"; do
		fct_queue_update "${pids_name}" "${tool##*/} (bun)" bun add -g "${tool}"
	done
}

fct_queue_uv_updates() {
	local pids_name="${1}"

	fct_queue_update "${pids_name}" "specify-cli (uv)" uv tool install specify-cli --force --from "git+https://github.com/github/spec-kit.git"
	fct_queue_update "${pids_name}" "playwright (uv)" uv tool upgrade playwright
	fct_queue_update "${pids_name}" "all uv tools" uv tool upgrade --all
}

fct_queue_custom_updates() {
	local pids_name="${1}"

	# Keep one-off commands explicit here. They do not share a common package-manager
	# pattern, so this section is the right place for special cases.
	fct_queue_update "${pids_name}" "claude (install.sh)" bash -c 'curl -fsSL https://claude.ai/install.sh | bash'
	fct_queue_update "${pids_name}" "specify check" specify check
	fct_queue_update "${pids_name}" "amp" amp update
}

fct_execute_updates() {
	log_info "Starting CLI tools update in parallel..."

	local pids=()
	local brew_count=2
	local update_bin_count=4
	local bun_count=7
	local uv_count=3
	local custom_count=3

	# Maintenance convention:
	# - Keep these counts in sync with the arrays/commands below.
	# - Add simple package-name-only updates to the corresponding array.
	# - Add unique commands to fct_queue_custom_updates() and update custom_count.
	fct_queue_brew_updates pids
	fct_queue_update_bin_updates pids
	fct_queue_bun_updates pids
	fct_queue_uv_updates pids
	fct_queue_custom_updates pids

	log_info "Job breakdown:"
	log_info "  Brew: ${brew_count}"
	log_info "  update-bin: ${update_bin_count}"
	log_info "  Bun: ${bun_count}"
	log_info "  UV: ${uv_count}"
	log_info "  Custom: ${custom_count}"
	log_info "  Total parallel jobs: ${#pids[@]}"
	log_info "Updates running in parallel (${#pids[@]} jobs)... waiting for completion..."

	# Wait for all background jobs. Individual failures are reported by fct_run_update,
	# so we do not stop early here.
	wait 2>/dev/null || true

	log_info "All CLI app updates completed!"
}

# ==============================================================================
# Main
# ==============================================================================

main() {
	fct_parse_arguments "$@"
	fct_execute_updates
}

main "$@"
