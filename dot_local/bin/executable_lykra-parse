#!/usr/bin/env bash
# lykra-parse — wrapper around `lit` (LiteParse) that applies user defaults
# and the _lykra.txt naming convention atomically.
#
# Usage:
#   lykra-parse <file-or-dir> [--fr]
#
# Behavior:
#   - File  → lit parse  → <basename>_lykra.txt next to input
#   - Dir   → lit batch-parse → <dirname>_lykra/ sibling, files renamed to *_lykra.txt
#   - Default config: ~/.config/liteparse/config.en.json
#   - --fr  → ~/.config/liteparse/config.fr.json

set -euo pipefail

fct_die() {
	printf 'lykra-parse: %s\n' "$1" >&2
	exit 1
}

fct_usage() {
	cat >&2 <<'EOF'
Usage: lykra-parse <file-or-dir> [--fr]

  <file-or-dir>  PDF, DOCX, image, or directory of supported files
  --fr           Use French OCR (default: English)

Configs: ~/.config/liteparse/config.{en,fr}.json
EOF
	exit 1
}

[[ $# -lt 1 || $# -gt 2 ]] && fct_usage

input_path=""
lang="en"

for arg in "$@"; do
	case "$arg" in
	--fr) lang="fr" ;;
	--en) lang="en" ;;
	-h | --help) fct_usage ;;
	-*) fct_die "unknown flag: $arg" ;;
	*)
		[[ -n "$input_path" ]] && fct_die "only one path argument allowed"
		input_path="$arg"
		;;
	esac
done

[[ -z "$input_path" ]] && fct_usage

config_file="$HOME/.config/liteparse/config.${lang}.json"
[[ -f "$config_file" ]] || fct_die "config not found: $config_file (run 'chezmoi apply')"

command -v lit >/dev/null 2>&1 || fct_die "lit not installed (run: bun i -g @llamaindex/liteparse)"

# Resolve to absolute path before changing directory
if [[ -e "$input_path" ]]; then
	abs_input="$(cd "$(dirname "$input_path")" && pwd)/$(basename "$input_path")"
else
	fct_die "not a file or directory: $input_path"
fi

# Tesseract.js drops *.traineddata in cwd. Pin a stable cache dir.
tessdata_cache="$HOME/.cache/liteparse/tessdata"
mkdir -p "$tessdata_cache"
cd "$tessdata_cache"

if [[ -f "$abs_input" ]]; then
	# Single file mode — keep original extension in output name
	dir="$(dirname "$abs_input")"
	base="$(basename "$abs_input")"
	output_file="${dir}/${base}_lykra.txt"

	printf 'Parsing file: %s\n' "$abs_input" >&2
	printf 'Output:       %s\n' "$output_file" >&2
	lit parse "$abs_input" --config "$config_file" -o "$output_file"
	printf 'Done: %s\n' "$output_file"

elif [[ -d "$abs_input" ]]; then
	# Directory mode
	clean_input="${abs_input%/}"
	output_dir="${clean_input}_lykra"

	printf 'Batch parsing: %s\n' "$clean_input" >&2
	printf 'Output dir:    %s\n' "$output_dir" >&2

	# Pre-flight: detect stem collisions that would clobber lit's output.
	# lit batch-parse writes <stem>.txt, stripping extension. Two inputs
	# sharing the same relative stem (e.g. foo.jpg + foo.png in the same
	# subdir) will overwrite each other; text from all but one is lost.
	collision_report="$(
		find "$clean_input" -type f -print0 |
			while IFS= read -r -d '' f; do
				rel="${f#"$clean_input"/}"
				reldir="$(dirname "$rel")"
				base="$(basename "$rel")"
				stem="${base%.*}"
				printf '%s\t%s\n' "${reldir}/${stem}" "$f"
			done |
			sort |
			awk -F'\t' '
				{
					if ($1 == prev_key) {
						if (!printed_key) {
							printf "⚠  lykra-parse: stem collision — output will be clobbered\n"
							printf "   stem: \"%s\"\n", $1
							printf "   files:\n     - %s\n", prev_file
							printed_key = 1
						}
						printf "     - %s\n", $2
						found = 1
					} else {
						if (printed_key) printf "   only one *.txt output will survive; text from the others will be LOST\n\n"
						printed_key = 0
					}
					prev_key = $1
					prev_file = $2
				}
				END {
					if (printed_key) printf "   only one *.txt output will survive; text from the others will be LOST\n"
					exit found ? 0 : 1
				}
			'
	)" || true

	if [[ -n "$collision_report" ]]; then
		printf '%s\n' "$collision_report" >&2
	fi

	mkdir -p "$output_dir"
	lit batch-parse "$clean_input" "$output_dir" --config "$config_file" --recursive

	# Rename outputs: look up original file by stem, preserve its extension.
	renamed=0
	while IFS= read -r -d '' f; do
		rel="${f#"$output_dir"/}"
		reldir="$(dirname "$rel")"
		stem="$(basename "$rel" .txt)"
		# Find the original input file matching this stem in the same relative dir
		src_dir="${clean_input}/${reldir}"
		original=""
		if [[ -d "$src_dir" ]]; then
			while IFS= read -r -d '' candidate; do
				cbase="$(basename "$candidate")"
				cstem="${cbase%.*}"
				if [[ "$cstem" == "$stem" ]]; then
					original="$cbase"
					break
				fi
			done < <(find "$src_dir" -maxdepth 1 -type f -print0)
		fi
		if [[ -n "$original" ]]; then
			new="${output_dir}/${reldir}/${original}_lykra.txt"
		else
			# Fallback: no matching input found, use stem only
			new="${output_dir}/${reldir}/${stem}_lykra.txt"
		fi
		# Normalize ./ prefix when reldir == .
		new="${new//\/.\//\/}"
		mv "$f" "$new"
		renamed=$((renamed + 1))
	done < <(find "$output_dir" -type f -name '*.txt' ! -name '*_lykra.txt' -print0)

	printf 'Done: %d files in %s\n' "$renamed" "$output_dir"
fi
